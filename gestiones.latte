{layout ./plantillas/@layout.latte}

{var $linkActivo = 'gestiones'}


{block content}
  <section class="section">
    <div class="container pt-5" data-aos-delay="0" data-aos="fade-up">
      <h1 class="text-uppercase fw-bold">
        Gestiones
      </h1>
      <div class="row g-3">
        {foreach $gestiones as $gestion}
          <div class="col-12 col-sm-6 col-md-4 mb-4">
            <div class="card h-100">
              {if $gestion['imagen'] === null}
                <img src="/assets/images/logo.webp" class="card-img-top object-fit-cover" alt="..."
                     style="max-height: 200px;">
              {else}
                <img src="/archivos/subidos/publicaciones/{$gestion['imagen']}" class="card-img-top object-fit-cover"
                     alt="..."
                     style="max-height: 200px;">
              {/if}
              <div class="card-body">
                <h5 class="card-title">{$gestion['titulo']}</h5>
                <p class="card-text">{$gestion['resumen']|truncate:100}</p>
                <a href="/gestiones-detalles.php?id={$gestion['id']}" class="btn btn-primary">Ver más</a>
              </div>
            </div>
          </div>

        {/foreach}
          {if !$gestiones}
          <div class="col-12">
            <div class="alert alert-info" role="alert">
              No hay avisos disponibles en este momento.
            </div>
          </div>
        {/if}
      </div>
    </div>
  </section>
{/block}
