{layout '../../../../templates/@portal.latte'}
{block title}Nuevo Mensaje{/block}

{block main}
  {include '../../../../templates/components/header-page.latte',
    title: 'Nuevo Mensaje',
    description: 'Envía una consulta o mensaje directo a los líderes del sindicato.',
    icon: 'bi-pencil-square'
  }

  <div class="row justify-content-center" x-data="contactForm">
    <div class="col-lg-8">
      {* Success State *}
      <template x-if="submitted">
        <div class="text-center py-5 animate__animated animate__fadeIn">
          <div class="mb-4">
            <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center shadow-sm" 
                 style="width: 80px; height: 80px;">
              <i class="bi bi-check-lg h1 mb-0"></i>
            </div>
          </div>
          <h2 class="fw-bold h3 mb-3">¡Mensaje enviado correctamente!</h2>
          <p class="text-muted mb-4" x-text="successMessage"></p>
          <div class="d-flex justify-content-center gap-3">
            <a href="mis-mensajes.php" class="btn btn-primary rounded-pill px-4">Ir a mis mensajes</a>
            <button @click="resetForm" class="btn btn-outline-secondary rounded-pill px-4">Enviar otro mensaje</button>
          </div>
        </div>
      </template>

      {* Form State *}
      <template x-if="!submitted">
        <div class="animate__animated animate__fadeIn">
          <form @submit.prevent="submitForm">
            <div class="mb-4">
              <label for="asunto" class="form-label fw-bold small text-muted text-uppercase tracking-wider">Asunto</label>
              <input type="text" id="asunto" class="form-control form-control-lg border-0 shadow-sm rounded-4 px-4 py-3"
                     placeholder="¿De qué trata tu mensaje?" x-model="formData.asunto" required>
            </div>

            <div class="mb-4">
              <label for="mensaje" class="form-label fw-bold small text-muted text-uppercase tracking-wider">Mensaje</label>
              <textarea id="mensaje" class="form-control form-control-lg border-0 shadow-sm rounded-4 px-4 py-3" rows="6"
                        placeholder="Escribe aquí tu mensaje detallado..." x-model="formData.mensaje" required></textarea>
            </div>

            <div class="d-grid pt-3">
              <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 shadow-lg" :disabled="loading">
                <span x-show="!loading"><i class="bi bi-send-fill me-2"></i>Enviar Mensaje Ahora</span>
                <span x-show="loading" class="spinner-border spinner-border-sm me-2" role="status"></span>
                <span x-show="loading">Enviando mensaje...</span>
              </button>
            </div>
          </form>
        </div>
      </template>
    </div>
  </div>
{/block}

{block scripts}
<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('contactForm', () => ({
        formData: {
            asunto: '',
            mensaje: ''
        },
        loading: false,
        submitted: false,
        successMessage: '',
        resetForm() {
            this.formData.asunto = '';
            this.formData.mensaje = '';
            this.submitted = false;
        },
        async submitForm() {
            this.loading = true;
            try {
                const response = await fetch('nuevo.php', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams(this.formData)
                });

                const result = await response.json();

                if (response.ok) {
                    this.successMessage = result.message;
                    this.submitted = true;
                    Alpine.store('toast').show({
                        type: 'success',
                        message: result.message
                    });
                } else {
                    Alpine.store('toast').show({
                        type: 'error',
                        message: result.error || 'Ocurrió un error al enviar el mensaje.'
                    });
                }
            } catch (error) {
                Alpine.store('toast').show({
                    type: 'error',
                    message: 'Error de conexión. Inténtalo de nuevo.'
                });
            } finally {
                this.loading = false;
            }
        }
    }));
});
</script>
{/block}
