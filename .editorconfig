root = true

[*]
ij_continuation_indent_size = 8
ij_formatter_off_tag = @formatter:off
ij_formatter_on_tag = @formatter:on
ij_formatter_tags_enabled = true
ij_smart_tabs = false
ij_visual_guides = 
ij_wrap_on_typing = false

[*.latte]
indent_size = tab
tab_width = 2
ij_latte_keep_blank_lines_in_code = 2
ij_latte_spaces_around_assignment_operators = true
ij_latte_spaces_around_bitwise_operators = true
ij_latte_spaces_around_equality_operators = true
ij_latte_spaces_around_logical_operators = true
ij_latte_spaces_around_multiplicative_operators = true
ij_latte_spaces_around_relational_operators = true
ij_latte_spaces_around_unary_operator = false
