<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Reporte de Miembros y Propuestas</title>
  <style>
    body {
      font-family: DejaVu Sans, sans-serif;
      font-size: 12px;
      color: #333;
    }
    h1 {
      text-align: center;
      margin-bottom: 30px;
      color: #2c3e50;
    }
    .miembro {
      margin-bottom: 30px;
      page-break-inside: avoid;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 15px;
    }
    th, td {
      border: 1px solid #aaa;
      padding: 6px 8px;
    }
    th {
      background-color: #f0f0f0;
      text-align: left;
    }
    .propuesta {
      border-left: 3px solid #0077aa;
      padding-left: 10px;
      margin-bottom: 8px;
    }
    .tipo {
      font-weight: bold;
      color: #0077aa;
      font-size: 11px;
    }
    hr {
      border: none;
      border-top: 1px solid #ddd;
      margin: 20px 0;
    }
  </style>
</head>
<body>

<h1>Reporte de Miembros y Propuestas</h1>

{foreach $miembros as $miembro}
  <div class="miembro">
    <table>
      <tr><th>Nombre</th><td>{$miembro['nombre']} {$miembro['apellidos']}</td></tr>
      <tr><th>Departamento</th><td>{$miembro['departamento']}</td></tr>
      <tr><th>Teléfono</th><td>{$miembro['telefono']}</td></tr>
      <tr><th>Fecha de ingreso</th><td>{$miembro['fecha_ingreso']|date:'d/m/Y'}</td></tr>
    </table>

    {if $miembro['propuestas']}
      <h4>Propuestas</h4>
      {foreach $miembro['propuestas'] as $p}
        <div class="propuesta">
          <div class="tipo">{$p['tipo']|capitalize}</div>
          <div>{$p['contenido']}</div>
        </div>
      {/foreach}
    {else}
      <p><em>Sin propuestas registradas.</em></p>
    {/if}
  </div>
  <hr>
{/foreach}

</body>
</html>
